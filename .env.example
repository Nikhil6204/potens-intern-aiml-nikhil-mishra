# Copy this file to .env and fill in your key(s).

# Which provider to use: "groq" (default, free tier) or "openai"
LLM_PROVIDER=groq

# Get a free key at https://console.groq.com
GROQ_API_KEY=GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile


# Retrieval / guardrail tuning (optional — sensible defaults are used if unset)
RETRIEVAL_TOP_K=5
MIN_SIMILARITY_TO_ATTEMPT=0.28
CONFIDENCE_REVIEW_THRESHOLD=0.55
CONTRADICTION_TOP_N_PAIRS=6
MIN_ALIGNMENT_SIMILARITY=0.15
